{
  "name": "interesting-america-hp",
  "version": "1.0.0",
  "description": "INTERESTING AMERICA - Modular 11ty Website",
  "scripts": {
    "cms:install": "npm --prefix cms ci",
    "cms:dev": "npm --prefix cms run dev",
    "cms:build": "npm --prefix cms run build",
    "cms:seed": "npm --prefix cms run seed",
    "cms:create-admin": "npm --prefix cms run create-admin",
    "build": "npm run cms:install && eleventy",
    "serve": "npm run cms:install && eleventy --serve --watch",
    "start": "npm run cms:install && eleventy --serve",
    "debug": "npm run cms:install && DEBUG=* eleventy"
  },
  "keywords": [
    "11ty",
    "static-site",
    "modular"
  ],
  "author": "INTERESTING AMERICA",
  "license": "MIT",
  "devDependencies": {
    "@11ty/eleventy": "^2.0.1",
    "markdown-it": "^14.1.1"
  }
}
