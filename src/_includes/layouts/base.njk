<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{% if page.url == '/' %}{{ site.name }}{% elif title %}{{ title }} | {{ site.name }}{% else %}{{ site.name }}{% endif %}</title>
  <meta name="description" content="{{ description or site.description }}">
  <link rel="icon" type="image/png" sizes="32x32" href="{{ favicon.png32DataUri }}">
  <link rel="icon" type="image/png" sizes="16x16" href="{{ favicon.png16DataUri }}">
  <link rel="icon" type="image/svg+xml" href="{{ '/favicon-20260619.svg' | url }}?v=20260619-favicon-01">
  <link rel="icon" href="{{ '/favicon-20260619.ico' | url }}?v=20260619-favicon-01" sizes="any">
  <link rel="shortcut icon" href="{{ '/favicon-20260619.ico' | url }}?v=20260619-favicon-01">
  <link rel="apple-touch-icon" sizes="180x180" href="{{ '/apple-touch-icon-20260619.png' | url }}?v=20260619-favicon-01">
  <link rel="apple-touch-icon-precomposed" href="{{ '/apple-touch-icon.png' | url }}?v=20260619-favicon-01">
  <link rel="manifest" href="{{ '/site.webmanifest' | url }}?v=20260619-favicon-01">
  <meta name="msapplication-TileImage" content="{{ '/android-chrome-192x192-20260619.png' | url }}?v=20260619-favicon-01">
  <meta name="theme-color" content="#0b1020">
  
  <link rel="stylesheet" href="{{ '/css/main.css' | url }}?v=20260618-01">
  <link rel="preload" as="image" href="{{ '/images/uploads/hero-atl-marriott-marquis.jpg' | url }}">
  <link rel="preload" as="image" href="{{ '/images/uploads/hero-st-regis-san-francisco.jpg' | url }}">
  <link rel="preload" as="image" href="{{ '/images/uploads/hero-los-angeles-ca.jpg' | url }}">
  <link rel="preload" as="image" href="{{ '/images/uploads/hero-dallas-tx.jpg' | url }}">
  <link rel="preload" as="image" href="{{ '/images/uploads/hero-santa-monica-ca.jpg' | url }}">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
</head>
<body class="{% if pageClasses %}{{ pageClasses }}{% endif %}">

  {% include "header.njk" %}
  
  <main id="main">
    {{ content | safe }}
  </main>
  
  {% if not hide_footer %}
    {% include "footer.njk" %}
  {% endif %}

  <script src="{{ '/js/main.js' | url }}?v=20260618-01" defer></script>
</body>
</html>
