{% set footerData = cms.footer %}
{% set headerData = cms.header %}
<footer class="site-footer">
  <div class="container footer-shell">
    <div class="footer-content">
      <div class="footer-signup-row">
        <p class="footer-copy">{{ footerData.newsletterPrompt }}</p>

        <form class="footer-newsletter" data-newsletter-form method="POST" action="{{ integrations.newsletterFormEndpoint }}" aria-label="Newsletter subscription form">
          <input type="hidden" name="success_path" value="{{ '/thank-you/' | url }}">
          <p class="form-honeypot" aria-hidden="true"><label>Do not fill this out: <input name="company_website"></label></p>
          <label class="footer-newsletter__field" for="footer-newsletter-email">
            <span class="sr-only">Email address</span>
            <input id="footer-newsletter-email" type="email" name="email" autocomplete="email" placeholder="{{ footerData.newsletterPlaceholder or 'Email address' }}" required>
          </label>
          <button class="footer-newsletter__button" type="submit">{{ footerData.newsletterButtonLabel or 'Subscribe' }}</button>
        </form>
      </div>
    </div>

    <div class="footer-bottom">
      <div class="footer-bottom__main">
        <div class="footer-brand">
          {% if footerData.logoPath or headerData.logoPath %}
            <img src="{{ (footerData.logoPath or headerData.logoPath) | url }}" alt="{{ headerData.brandName or cms.seoSettings.siteName or site.name }}" class="footer-logo__img">
          {% endif %}
        </div>

        <nav class="footer-nav" aria-label="Footer navigation">
          <ul>
            {%- for item in footerData.navItems -%}
              <li><a href="{{ item.url | url }}">{{ item.label }}</a></li>
            {%- endfor -%}
          </ul>
        </nav>
      </div>

      <div class="footer-legal">
        <p>{{ footerData.copyrightLineRendered or footerData.copyrightLine }}</p>
      </div>
    </div>
  </div>
</footer>
