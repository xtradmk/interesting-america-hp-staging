<footer class="site-footer">
  <div class="container footer-shell">
    <div class="footer-content">
      <div class="footer-signup-row">
        <p class="footer-copy">Sign up now and stay updated about accommodation, transfers, and hospitality at the major global sports events:</p>

        <form class="footer-newsletter" data-newsletter-form aria-label="Newsletter subscription form">
          <label class="footer-newsletter__field" for="footer-newsletter-email">
            <span class="sr-only">Email address</span>
            <input id="footer-newsletter-email" type="email" name="email" autocomplete="email" placeholder="Email address" required>
          </label>
          <button class="footer-newsletter__button" type="submit">Subscribe</button>
        </form>
      </div>
    </div>

    <div class="footer-bottom">
      <div class="footer-bottom__main">
        <div class="footer-brand">
          <img src="{{ '/images/uploads/interesting-sports-black-.png' | url }}" alt="{{ site.name }}" class="footer-logo__img">
        </div>

        <nav class="footer-nav" aria-label="Footer navigation">
          <ul>
            <li><a href="{{ '/' | url }}">Home</a></li>
            {%- for item in site.nav -%}
              <li><a href="{{ item.url | url }}">{{ item.text }}</a></li>
            {%- endfor -%}
            <li><a href="{{ '/t-c/' | url }}">T&amp;C</a></li>
            <li><a href="{{ '/privacy-policy/' | url }}">Privacy Policy</a></li>
          </ul>
        </nav>
      </div>

      <div class="footer-legal">
        <p>© {% year %} {{ site.name }}. All rights reserved.</p>
      </div>
    </div>
  </div>
</footer>
