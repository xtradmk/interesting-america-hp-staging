<header class="site-header">
  <div class="container">
    <a href="{{ '/' | url }}" class="logo" aria-label="{{ site.name }} - Back to Home">
      <img src="{{ '/images/uploads/interesting-sports-black-.png' | url }}" alt="{{ site.name }}" class="logo__img">
    </a>

    <nav class="site-nav" aria-label="Main navigation">
      <ul class="nav-list nav-island">
        {%- for item in site.nav -%}
          <li class="nav-item{% if page.url == item.url %} nav-item--active{% endif %}">
            <a href="{{ item.url | url }}" class="nav-link">{{ item.text }}</a>
          </li>
        {%- endfor -%}
      </ul>
    </nav>

    <button class="mobile-menu-trigger" type="button" aria-expanded="false" aria-controls="mobile-menu-panel">
      <span class="mobile-menu-trigger__label">Menü</span>
    </button>

    <div class="mobile-menu-panel" id="mobile-menu-panel" hidden>
      <ul class="mobile-menu-list">
        {%- for item in site.nav -%}
          <li class="mobile-menu-item">
            <a href="{{ item.url | url }}" class="mobile-menu-link">{{ item.text }}</a>
          </li>
        {%- endfor -%}
      </ul>
    </div>
  </div>
</header>