<section class="hero section hero--photo hero--subpage"
  style="--hero-overlay-opacity: {{ (hero_dimming_percent or 100) / 100 }}"
  data-image1="{{ hero_image1 | url }}"
  data-caption1="{{ hero_caption1 }}"
  {% if hero_image2 %}data-image2="{{ hero_image2 | url }}"{% endif %}
  {% if hero_caption2 %}data-caption2="{{ hero_caption2 }}"{% endif %}
  {% if hero_image3 %}data-image3="{{ hero_image3 | url }}"{% endif %}
  {% if hero_caption3 %}data-caption3="{{ hero_caption3 }}"{% endif %}
  {% if hero_image4 %}data-image4="{{ hero_image4 | url }}"{% endif %}
  {% if hero_caption4 %}data-caption4="{{ hero_caption4 }}"{% endif %}
  {% if hero_image5 %}data-image5="{{ hero_image5 | url }}"{% endif %}
  {% if hero_caption5 %}data-caption5="{{ hero_caption5 }}"{% endif %}>
  <div class="hero-bg-track" aria-hidden="true">
    <div class="hero-bg hero-bg--active" style="background-image:url('{{ hero_image1 | url }}')"></div>
    <div class="hero-bg hero-bg--next" style="background-image:url('{{ (hero_image2 or hero_image1) | url }}')"></div>
    <div class="hero-bg hero-bg--css hero-bg--1" style="background-image:url('{{ hero_image1 | url }}')"></div>
    {% if hero_image2 %}<div class="hero-bg hero-bg--css hero-bg--2" style="background-image:url('{{ hero_image2 | url }}')"></div>{% endif %}
    {% if hero_image3 %}<div class="hero-bg hero-bg--css hero-bg--3" style="background-image:url('{{ hero_image3 | url }}')"></div>{% endif %}
    {% if hero_image4 %}<div class="hero-bg hero-bg--css hero-bg--4" style="background-image:url('{{ hero_image4 | url }}')"></div>{% endif %}
    {% if hero_image5 %}<div class="hero-bg hero-bg--css hero-bg--5" style="background-image:url('{{ hero_image5 | url }}')"></div>{% endif %}
    <div class="hero-bg-overlay"></div>
  </div>

  <div class="wrap-wide fade in">
    <div class="hero-copy-block hero-copy-block--subpage">
      {% if hero_kicker %}
        <p class="hero-kicker">{{ hero_kicker }}</p>
      {% endif %}
      <h1 class="hero-page-title">{{ hero_title | safe }}</h1>
      {% if hero_copy %}
        <p class="hero-page-copy">{{ hero_copy }}</p>
      {% endif %}
      {% if hero_link_url and hero_link_label %}
        <a class="hero-link-cta hero-link-cta--static is-visible" href="{{ hero_link_url | url }}">
          <span class="hero-link-cta__text">{{ hero_link_label }}</span>
          <span class="hero-link-cta__icon" aria-hidden="true">
            <svg viewBox="0 0 19 19" role="presentation" focusable="false">
              <path d="M14.458 10.687 L0 10.688 L0 8.313 L14.458 8.313 L7.808 1.663 L9.5 0 L19 9.5 L9.5 19 L7.808 17.337 Z" fill="currentColor"></path>
            </svg>
          </span>
        </a>
      {% endif %}
    </div>
  </div>

  {% if hero_caption1 %}
    <p class="hero-photo-caption" id="hero-photo-caption">{{ hero_caption1 }}</p>
  {% endif %}

  {% if hero_image2 %}
    <div class="hero-slider-ui" aria-label="Header image controls">
      <button class="hero-slider-btn" type="button" data-hero-prev aria-label="Previous image">‹</button>
      <button class="hero-slider-btn" type="button" data-hero-next aria-label="Next image">›</button>
    </div>
  {% endif %}
</section>
